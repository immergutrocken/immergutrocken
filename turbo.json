{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "dev": {
      "outputs": ["dist/**", "build/**"]
    },
    "build": {
      "outputs": ["public/**", ".next/**"],
      "dependsOn": ["^build"],
      "env": ["MAILJET_*", "SANITY_STUDIO_*"]
    },
    "test": {
      "outputs": ["dist/**", "build/**"]
    },
    "test:ci": {
      "outputs": ["dist/**", "build/**"]
    },
    "test:e2e": {
      "cache": false,
      "env": ["SANITY_STUDIO_*", "E2E_BASE_URL", "CI"]
    },
    "lint": {}
  }
}
